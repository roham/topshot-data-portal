# NBA Top Shot Data Portal — environment variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real keys.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project: topshot-data-portal (dedicated)
# Provision via dashboard at https://supabase.com/dashboard or via Management API.
# After provisioning, copy from Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                 # publishable / anon key (safe in browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                     # server-only, NEVER prefix with NEXT_PUBLIC_

# Connection string for direct SQL (used by ETL scripts running outside Supabase):
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── BigQuery (for ETL only — not used by Next.js app) ─────────────────────────
# Service account with roles/bigquery.dataViewer + roles/bigquery.jobUser on dapperlabs-data.
# Locally: path to the JSON key file. In GH Actions: full JSON contents via secrets.GCP_BQ_SA_JSON.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/bq-sa.json
BQ_PROJECT_ID=dapperlabs-data
BQ_DATASET=production_sem_open

# ─── Top Shot public GraphQL (legacy fallback only) ────────────────────────────
# Kept for username→flow_address resolution + emergency live-refresh path.
# Most queries should hit Supabase, not this.
TOPSHOT_GRAPHQL_URL=https://public-api.nbatopshot.com/graphql

# ─── Build / dev ───────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
